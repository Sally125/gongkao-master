generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ==================== 用户数据层 ====================
model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  passwordHash  String
  avatar        String?
  dailyGoalMinutes Int    @default(60)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
  exams    Exam[]
  studyPlans StudyPlan[]
  reviews  ReviewRecord[]
  studyLogs StudyLog[]
  questionBanks QuestionBank[]
  practiceRecords PracticeRecord[]
  tasks Task[]
  focusSessions FocusSession[]
  idioms Idiom[]
  wrongQuestions WrongQuestion[]
  materials UserMaterial[]
  dailyCards DailyCard[]
  userSettings UserSettings?

  @@map("users")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

// ==================== 个人设置 ====================
model UserSettings {
  id              String   @id @default(cuid())
  userId          String   @unique
  theme           String   @default("light")
  notificationEnabled Boolean @default(true)
  reminderTime    String   @default("08:00")
  language        String   @default("zh-CN")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("user_settings")
}

// ==================== 考试管理层 ====================
model Exam {
  id         String   @id @default(cuid())
  userId     String
  examName   String
  nodes      String   @default("{}")
  isEnabled  Boolean  @default(true)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  studyPlans StudyPlan[]

  @@map("exams")
}

// ==================== 学习计划层 ====================
model StudyPlan {
  id          String   @id @default(cuid())
  userId      String
  examId      String?
  title       String
  description String?
  startDate   String
  endDate     String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  exam Exam? @relation(fields: [examId], references: [id], onDelete: SetNull)
  items StudyPlanItem[]

  @@map("study_plans")
}

model StudyPlanItem {
  id          String   @id @default(cuid())
  planId      String
  title       String
  description String?
  date        String
  isCompleted Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  plan StudyPlan @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@map("study_plan_items")
}

// ==================== 复盘记录层 ====================
model ReviewRecord {
  id          String   @id @default(cuid())
  userId      String
  title       String
  content     String
  mood        String?
  tags        String?
  reviewDate  String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("review_records")
}

// ==================== 数据统计层（学习日志）====================
model StudyLog {
  id          String   @id @default(cuid())
  userId      String
  date        String
  minutes     Int      @default(0)
  questions   Int      @default(0)
  correct     Int      @default(0)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("study_logs")
}

// ==================== 题库练习层 ====================
model QuestionBank {
  id          String   @id @default(cuid())
  userId      String
  name        String
  description String?
  category    String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  questions Question[]
  practiceRecords PracticeRecord[]

  @@map("question_banks")
}

model Question {
  id          String   @id @default(cuid())
  bankId      String
  content     String
  options     String
  answer      String
  explanation String?
  difficulty  String?
  tags        String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  bank QuestionBank @relation(fields: [bankId], references: [id], onDelete: Cascade)
  practiceRecords PracticeRecord[]

  @@map("questions")
}

model PracticeRecord {
  id          String   @id @default(cuid())
  userId      String
  questionId  String
  bankId      String
  userAnswer  String
  isCorrect   Boolean
  timeSpent   Int?
  practicedAt DateTime @default(now())
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
  bank QuestionBank @relation(fields: [bankId], references: [id], onDelete: Cascade)

  @@map("practice_records")
}

// ==================== 智能Todo层 ====================
model Task {
  id                String   @id @default(cuid())
  userId            String
  title             String
  priority          String   @default("中")
  estimatedMinutes  Int      @default(30)
  deadline          String?
  subjectTag        String?
  status            String   @default("todo")
  source            String   @default("manual")
  sortOrder         Int      @default(0)
  imageUrl          String?
  startedAt         DateTime?
  pausedAt          DateTime?
  totalPausedSeconds Int     @default(0)
  actualSeconds      Int?
  completedAt        DateTime?
  enteredAt          DateTime @default(now())
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  focusSessions FocusSession[]

  @@map("tasks")
}

model FocusSession {
  id          String   @id @default(cuid())
  userId      String
  taskId      String?
  startTime   DateTime
  endTime     DateTime?
  duration    Int      @default(0)
  mode        String   @default("pomodoro")
  paused      Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task? @relation(fields: [taskId], references: [id], onDelete: SetNull)

  @@map("focus_sessions")
}

// ==================== 易错成语层 ====================
model Idiom {
  id            String   @id @default(cuid())
  userId        String
  word          String   // 成语
  meaning       String   // 释义
  notes         String?  // 备注

  // 记忆进度
  reviewStage   Int      @default(0)  // 0=新学, 1-5=复习阶段, 6=已掌握
  nextReviewDate DateTime @default(now()) // 下次复习日期
  isMastered    Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("idioms")
}

// ==================== 复盘记录层 ====================
model WrongQuestion {
  id            String   @id @default(cuid())
  userId        String
  question      String   // 题干内容（文字或图片URL）
  questionType  String   // 输入类型：text / image / ocr
  myAnswer      String   // 我的答案
  correctAnswer String   // 正确答案
  errorReason   String   // 错误原因（计算失误/知识点盲区/审题不清等）
  questionModule String  // 题型/知识模块（资料分析/中心理解等）
  isGuessed     Boolean  @default(false) // 蒙对标记
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("wrong_questions")
}

// ==================== 申论积累层 ====================
model Article {
  id          String   @id @default(cuid())
  title       String
  source      String   // 人民日报/新华网
  url         String
  author      String?
  content     String   // 原文HTML/纯文本
  domain      String   // 基层治理/科技创新/民生保障/生态文明/法治建设/文化自信
  publishDate DateTime
  analysis    String?  // AI拆解结果JSON
  createdAt   DateTime @default(now())

  materials UserMaterial[]
  dailyCards DailyCard[]

  @@map("articles")
}

model UserMaterial {
  id        String   @id @default(cuid())
  userId    String
  articleId String
  type      String   // golden_sentence/case/norm_word/countermeasure
  content   String   // 用户收藏的原文内容
  tags      String?  // 主题标签JSON
  createdAt DateTime @default(now())

  user    User    @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)

  @@map("user_materials")
}

model DailyCard {
  id          String   @id @default(cuid())
  userId      String
  articleId   String?
  content     String   // 金句/规范词原文
  source      String   // 出处（文章标题）
  topic       String   // 适用主题
  reviewStage Int      @default(0)
  nextReview  DateTime @default(now())
  createdAt   DateTime @default(now())

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  article Article? @relation(fields: [articleId], references: [id], onDelete: SetNull)

  @@map("daily_cards")
}